# Tadpole OS Sovereign Engine Configuration
# Copy this file to .env and adjust values for your local environment.

# --- Core Networking ---
BIND_ADDRESS=127.0.0.1:8080
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Security & Governance ---
NEURAL_TOKEN=your_master_token_here
NEURAL_ENGINE_ACCESS_TOKEN=your_internal_access_token
AGGRESSIVE_SECURITY=false
PRIVACY_MODE=true
AUTO_APPROVE_SAFE_SKILLS=true

# --- Resource Management ---
MAX_AGENTS=10
MAX_CLUSTERS=5
MAX_SWARM_DEPTH=3
ENGINE_RATE_LIMIT=100
HEARTBEAT_INTERVAL_SECS=30

# --- Vector Database (LanceDB) ---
WORKSPACE_ROOT=./data
LANCEDB_DRIFT_THRESHOLD=0.1
LANCEDB_DEDUPE_THRESHOLD=0.9
SKIP_DB_SEED=false

# --- LLM Providers ---
OPENAI_API_KEY=sk-placeholder
GROQ_API_KEY=gsk-placeholder
OLLAMA_BASE_URL=http://localhost:11434

# --- Audio & Voice ---
VAD_MODEL_PATH=./models/silero_vad.onnx
WHISPER_MODEL_PATH=./models/whisper_base.onnx
PIPER_MODEL_PATH=./models/piper_voice.onnx

# --- Mission Context ---
CLUSTER_ID=default-swarm
DISABLE_TELEMETRY=false

# --- Infrastructure ---
OLLAMA_HOST=http://localhost:11434
PORT=8080
RESOURCE_ROOT=./resources
TADPOLE_ALLOW_LOCAL_HTTP=true
KUBERNETES_SERVICE_HOST=
STATIC_DIR=./static
DATABASE_URL=sqlite:tadpole.db
AUDIT_PRIVATE_KEY=your_private_key_here

# --- Tuning & Thresholds ---
MAX_TASK_LENGTH=10000
DEFAULT_AGENT_BUDGET_USD=10.0
SME_SYNC_INTERVAL_MINS=60

# --- External Services ---
GOOGLE_API_KEY=
DISCORD_WEBHOOK=
TADPOLE_NULL_PROVIDERS=false
