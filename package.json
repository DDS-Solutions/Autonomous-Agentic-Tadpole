{
  "name": "AI-tTadpole-OS",
  "private": true,
  "version": "1.1.57",
  "keywords": [
    "react",
    "rust",
    "typescript",
    "mcp",
    "self-hosted",
    "autonomous-agents",
    "ai-safety",
    "swarm-intelligence",
    "ai-agents",
    "moonshots",
    "mythos",
    "local-first",
    "spud",
    "ai-agents-automation",
    "swarm-intelligence-multi-agent-llm-automation",
    "autonomous-agents-system"
  ],
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "engine": "cargo run --manifest-path server-rs/Cargo.toml",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:icon": "tauri icon",
    "build:linux:light": "powershell -ExecutionPolicy Bypass -File scripts/build-linux-light.ps1",
    "build:linux:upload": "powershell -ExecutionPolicy Bypass -File scripts/build-linux-light.ps1 -Upload",
    "deploy:linuxlite66": "powershell -ExecutionPolicy Bypass -File scripts/deploy-linuxlite.ps1",
    "audit:observability": "node scripts/verify_observability_sync.cjs",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@google/genai": "^1.50.1",
    "@huggingface/transformers": "^4.2.0",
    "@msgpack/msgpack": "^3.1.3",
    "@types/dagre": "^0.7.54",
    "brace-expansion": "^5.0.5",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "dexie": "^4.4.2",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.34.3",
    "groq-sdk": "^1.1.1",
    "lodash": "^4.18.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.2",
    "reactflow": "^11.11.4",
    "tailwind-merge": "^3.5.0",
    "uuid": "^14.0.0",
    "ws": "^8.20.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/prop-types": "^15.7.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.0",
    "postcss": "^8.5.12",
    "scheduler": "^0.27.0",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.2.0",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom",
    "@types/react": "$@types/react",
    "@types/react-dom": "$@types/react-dom",
    "vite": "$vite",
    "vite-plugin-pwa": {
      "vite": "$vite"
    },
    "serialize-javascript": "^7.0.4",
    "esbuild": "^0.25.0",
    "protobufjs": "^8.0.1"
  }
}
